datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. LES UTILISATEURS (Chefs, Agents, et Vous)
model User {
  id         String   @id @default(cuid())
  nom        String
  prenom     String
  telephone  String   @unique
  motDePasse String
  role       Role     @default(AGENT)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt // 🟢 Conservé

  // 🟢 NOUVELLE LIAISON MULTI-ZONES PERFECTIONNÉE
  zones      Zone[]

  // Relations historiques conservées à 100%
  creditsAccordez    VenteCredit[]   @relation("ChefQuiAAccorde")
  collectesEffectuees FluxVersement[] @relation("AgentQuiACollecte")
  collectesValidees   FluxVersement[] @relation("ChefQuiAValide")
}

enum Role {
  CHEF
  AGENT
  SUPER_ADMIN
}

// 🟢 NOUVEAU MODÈLE CENTRALISÉ POUR LES MARCHÉS
model Zone {
  id        String   @id @default(cuid())
  nom       String   @unique // ex: "Marché Ouando", "Marché Tokpota"
  adresse   String?  // Emplacement ou quartier global
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations inverses automatiques
  agents    User[]     // Un marché peut avoir plusieurs agents (Many-to-Many)
  clientes  Cliente[]  // Un marché contient plusieurs mamas (One-to-Many)
}

// 2. LES CLIENTES (Les Bonnes Dames)
model Cliente {
  id         String   @id @default(cuid())
  nom        String
  prenom     String?  // Ajouté pour séparer proprement nom/prénom
  telephone  String?  @unique
  adresse    String?  // Allée, numéro d'étal ou boutique au marché
  
  // Sécurisé avec Decimal pour éviter les bugs d'arrondis sur les comptes.
  soldeDette Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt // 🟢 Conservé

  // 🟢 LIAISON CHIRURGICALE À LA ZONE UNIQUE
  zoneId     String
  zone       Zone     @relation(fields: [zoneId], references: [id])

  // Relations One-to-Many
  credits    VenteCredit[] 
  versements FluxVersement[] 
}

// 3. LES PRODUITS INVENTAIRE
model Produit {
  id            String   @id @default(cuid())
  nom           String   @unique 
  quantiteStock Int      @default(0) 
  prixUnitaire  Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt // 🟢 Conservé

  // Relations avec tes noms historiques exacts
  approvisionnements Approvisionnement[] // 🟢 Conservé
  lignesVente        LigneVenteCredit[]   // 🟢 Conservé
}

// 4. LES ENTRÉES DE STOCK (Quand le chef achète des marchandises)
model Approvisionnement {
  id        String   @id @default(cuid())
  quantite  Int
  dateAchat DateTime @default(now())
  
  // Relations Many-to-One
  produitId String
  produit   Produit  @relation(fields: [produitId], references: [id])
}

// 5. LES VENTES À CRÉDIT (La dette augmente, le stock baisse)
model VenteCredit {
  id           String   @id @default(cuid())
  montantTotal Decimal  @db.Decimal(12, 2)
  dateVente    DateTime @default(now())

  // Relation Many-to-One
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])

  // Relation Many-to-One : Relie le chef exact qui a accordé le crédit
  chefId       String
  chef         User     @relation("ChefQuiAAccorde", fields: [chefId], references: [id])

  // Relation One-to-Many : Nom historique conservé
  lignesVente  LigneVenteCredit[] // 🟢 Conservé
}

// Table intermédiaire pour gérer le détail d'une vente à crédit (Le Panier)
model LigneVenteCredit {
  id           String      @id @default(cuid())
  quantite     Int
  prixApplique Decimal     @db.Decimal(12, 2)
  
  venteCreditId String
  venteCredit   VenteCredit @relation(fields: [venteCreditId], references: [id], onDelete: Cascade)
  
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])
}

// 6. LES VERSEMENTS DU TERRAIN (La dette diminue après validation du soir)
model FluxVersement {
  id             String          @id @default(cuid())
  montantVerse   Decimal         @db.Decimal(12, 2)
  statut         StatutVersement @default(EN_ATTENTE)
  dateCollecte   DateTime        @default(now())
  dateValidation DateTime?

  // Relation Many-to-One
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // Relation Many-to-One : L'agent de terrain qui a collecté l'argent
  agentId String
  agent   User   @relation("AgentQuiACollecte", fields: [agentId], references: [id])

  // Relation Many-to-One (Optionnelle) : Le chef qui a validé les espèces le soir
  chefId String?
  chef   User?   @relation("ChefQuiAValide", fields: [chefId], references: [id])
}

enum StatutVersement {
  EN_ATTENTE
  VALIDE
}
